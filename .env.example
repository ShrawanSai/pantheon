# =============================================================================
# Pantheon — Environment Variable Reference
# =============================================================================
# Copy this file to .env (local dev) or set these in Railway / Vercel.
# Variables marked [REQUIRED] will cause the app to refuse to start if missing.
# Variables marked [REQUIRED when billing=on] are only required when
# CREDIT_ENFORCEMENT_ENABLED=true.
# =============================================================================

# ---- OpenRouter -------------------------------------------------------
# [REQUIRED] API key for all LLM calls (backend API + arq worker)
OPENROUTER_API_KEY=replace_me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ---- Supabase ---------------------------------------------------------
# [REQUIRED] Your Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# [REQUIRED] Public anon key (safe to expose in the browser via NEXT_PUBLIC_)
SUPABASE_ANON_KEY=replace_me
# [REQUIRED] Service role key — NEVER expose this to the browser
SUPABASE_SERVICE_ROLE_KEY=replace_me
# Storage bucket for uploaded files
SUPABASE_STORAGE_BUCKET=pantheon-files

# ---- Postgres (Supabase) ----------------------------------------------
# [REQUIRED for migrations] Direct connection — used by Alembic only
DATABASE_URL=postgresql+psycopg://user:password@db.your-project-ref.supabase.co:5432/postgres
# [REQUIRED for runtime] Pooler connection via PgBouncer — used by the API
DATABASE_POOL_URL=postgresql+psycopg://user:password@pooler.your-project-ref.supabase.co:6543/postgres

# ---- Redis (arq background worker) ------------------------------------
# [REQUIRED for worker] Redis connection string
# On Railway: use the Railway Redis plugin — its REDIS_URL is injected automatically
REDIS_URL=redis://localhost:6379/0

# ---- API Service (Railway) -------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# [REQUIRED] Comma-separated list of allowed browser origins.
# Must include your Vercel deployment URL and any preview branch URLs.
# An empty value blocks ALL browser requests.
API_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ---- Stripe (Billing) ------------------------------------------------
# [REQUIRED when billing=on] Stripe secret key (starts with sk_live_ or sk_test_)
STRIPE_SECRET_KEY=sk_test_replace_me
# [REQUIRED when billing=on] Webhook signing secret from the Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Toggle credit enforcement — set to true only when Stripe keys are live
CREDIT_ENFORCEMENT_ENABLED=false
TOP_UP_MIN_USD=1.0
TOP_UP_MAX_USD=500.0
CREDITS_PER_USD=33.33
LOW_BALANCE_THRESHOLD=5.0

# ---- Admin -----------------------------------------------------------
# Comma-separated Supabase user UUIDs that have admin privileges
ADMIN_USER_IDS=

# ---- Tavily (Web Search Tool) ----------------------------------------
# Optional — leave blank to disable the web search tool for agents
TAVILY_API_KEY=

# ---- Context / LLM Tuning (optional, safe defaults apply) -----------
CONTEXT_MAX_OUTPUT_TOKENS=2048
CONTEXT_SUMMARY_TRIGGER_RATIO=0.70
CONTEXT_PRUNE_TRIGGER_RATIO=0.90
CONTEXT_MANDATORY_SUMMARY_TURN=8
CONTEXT_DEFAULT_MODEL_LIMIT=8192
CONTEXT_RECENT_TURNS_TO_KEEP=4
AGENT_PRIVATE_CONTEXT_TURNS_KEEP=3
FILE_MAX_BYTES=1048576

# ---- Orchestrator Tuning (optional, safe defaults apply) ------------
ORCHESTRATOR_MAX_DEPTH=3
ORCHESTRATOR_MAX_SPECIALIST_INVOCATIONS=12
ORCHESTRATOR_MANAGER_MODEL_ALIAS=gemini-flash
SUMMARIZER_MODEL_ALIAS=gemini-flash
PRICING_VERSION=2026-02-20

# ---- Rate Limiting (optional, safe defaults apply) ------------------
RATE_LIMIT_TURNS_PER_MINUTE=10
RATE_LIMIT_TURNS_PER_HOUR=60

# =============================================================================
# Frontend-only — set these in Vercel environment variables
# (or apps/web/.env.local for local dev)
# =============================================================================
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
